{
  "name": "alpha-mind",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:backend": "pnpm --filter @alpha-mind/backend run start:dev",
    "dev:market-data": "pnpm --filter @alpha-mind/market-data-service run start:dev",
    "dev:frontend": "pnpm --filter @alpha-mind/frontend run dev",
    "build": "pnpm -r run build",
    "build:backend": "pnpm --filter @alpha-mind/backend run build",
    "build:market-data": "pnpm --filter @alpha-mind/market-data-service run build",
    "build:frontend": "pnpm --filter @alpha-mind/frontend run build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "esbuild", "unrs-resolver"]
  }
}
